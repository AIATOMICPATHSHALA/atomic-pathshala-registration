# Google Apps Script Web App URL.
# Deploy Apps Script as "Execute as: Me" and "Who has access: Anyone",
# then paste the generated /exec URL below.
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX/exec

# Backward-compatible fallback if this already exists in an older deployment.
NEXT_PUBLIC_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX/exec
